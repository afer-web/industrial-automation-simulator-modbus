<Window x:Class="ModbusAutomationSimulator.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ModbusAutomationSimulator — Dashboard"
        Background="#FF1B2430"
        Width="1080"
        Height="740"
        FontFamily="Segoe UI" Icon="/Conveyor.png">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE8EEF9" />
        </Style>
        <Style TargetType="Button" x:Key="CmdBtn">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#FF2E3F54" />
            <Setter Property="Foreground" Value="#FFE8EEF9" />
            <Setter Property="BorderBrush" Value="#FF4B6185" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Padding="12" CornerRadius="6" Background="#FF263347">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Industrial cell — sinottico" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#FFA9BEDC"
                               Text="Simulatore + server Modbus TCP (vedi porta in appsettings). Controlli anche via coil FC05 supervisory." />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="8,0" VerticalAlignment="Center" Foreground="#FF8FA6C9" Text="Torretta" />
                    <Ellipse Width="22" Height="22" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF39465A" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LampGreen}" Value="True">
                                        <Setter Property="Fill" Value="#FF4CD97B" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Ellipse Width="22" Height="22" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF39465A" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LampAmber}" Value="True">
                                        <Setter Property="Fill" Value="#FFE7B84A" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Ellipse Width="22" Height="22" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF39465A" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LampRed}" Value="True">
                                        <Setter Property="Fill" Value="#FFE25555" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2.2*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Sinottico -->
            <UniformGrid Rows="2" Columns="2" Margin="0,0,0,10">
                <Border Margin="6" Padding="12" CornerRadius="8" BorderBrush="#FF3D4F6A" BorderThickness="1"
                        Background="#FF1F2938">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Text="Nastro ingresso" />
                        <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="#FFC5D8F8"
                                   Text="{Binding SensorConveyor, StringFormat=Nastro motor on: {0}}" />
                        <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="#FFC5D8F8"
                                   Text="{Binding SensorEntryPiece, StringFormat=Pezzo in ingresso: {0}}" />
                    </StackPanel>
                </Border>
                <Border Margin="6" Padding="12" CornerRadius="8" BorderBrush="#FF3D4F6A" BorderThickness="1"
                        Background="#FF1F2938">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Text="Stazione lavorazione" />
                        <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="#FFC5D8F8"
                                   Text="{Binding SensorStationPiece, StringFormat=Pezzo agganciato stazione: {0}}" />
                    </StackPanel>
                </Border>
                <Border Margin="6" Padding="12" CornerRadius="8" BorderBrush="#FF3D4F6A" BorderThickness="1"
                        Background="#FF1F2938">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Text="Controllo qualità" />
                        <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="#FFC5D8F8"
                                   Text="{Binding SensorQualityLane, StringFormat=Q.C. attiva: {0}}" />
                    </StackPanel>
                </Border>
                <Border Margin="6" Padding="12" CornerRadius="8" BorderBrush="#FF3D4F6A" BorderThickness="1"
                        Background="#FF1F2938">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="14" Text="Magazzino uscita" />
                        <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="#FFC5D8F8"
                                   Text="{Binding SensorOutboundReady, StringFormat=Binario outbound ready: {0}}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- KPI + allarmi -->
            <Border Margin="6,355,6,1" Padding="14" CornerRadius="8"
                    Background="#FF1F2938"
                    BorderBrush="#FF3D4F6A" BorderThickness="1" Grid.RowSpan="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Telemetria ciclo macchina"
                                   Foreground="#FF93B5E9" />
                        <TextBlock Margin="0,10,0,0" FontSize="13"
                                   Text="{Binding MachinePhase, StringFormat=Fase: {0}}" />
                        <TextBlock Margin="0,8,0,0" FontSize="13"
                                   Text="{Binding AlarmActive, StringFormat=Allarme attivo (registro): {0}}" />
                        <TextBlock Margin="0,8,0,0" FontSize="13"
                                   Text="{Binding PhaseMs, StringFormat='Timer fase (ms): {0}'}" />
                        <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="#FF9FB3D9"
                                   Text="{Binding StatusWordHex, StringFormat=Status bitmask: {0}}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="13" Foreground="#FF93B5E9" FontWeight="SemiBold" Text="Contatori produzione"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,14,0" FontSize="20" FontWeight="Bold"
                                       Foreground="#FF74E3A9"
                                       Text="{Binding GoodCount, StringFormat=Buoni: {0}}" />
                            <TextBlock FontSize="20" FontWeight="Bold"
                                       Foreground="#FFFF9B7A"
                                       Text="{Binding ScrapCount, StringFormat=Scarti: {0}}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="2" Rows="2" Columns="4" Margin="0,4,0,0">
                <Button Style="{StaticResource CmdBtn}" Content="START automatico"
                        Command="{Binding StartCycleCommand}" />
                <Button Style="{StaticResource CmdBtn}" Content="STOP (fine ciclo)" Command="{Binding SoftStopCommand}" />
                <Button Style="{StaticResource CmdBtn}" Content="Emergency STOP"
                        Background="#FF5B2F2F" Command="{Binding EmergencyStopCommand}" />
                <Button Style="{StaticResource CmdBtn}" Content="Reset sicurezza" Command="{Binding ResetSafetyCommand}" />
                <Button Style="{StaticResource CmdBtn}" Content="Fault injection" Command="{Binding FaultInjectCommand}" />
                <Button Style="{StaticResource CmdBtn}" Content="Ack allarmi" Command="{Binding AckAlarmsCommand}" />
            </UniformGrid>
        </Grid>
    </DockPanel>
</Window>
